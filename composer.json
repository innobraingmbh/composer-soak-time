{
    "name": "innobrain/soak-time",
    "description": "Protects against supply chain attacks by filtering recently published packages.",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.2",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Innobrain\\SoakTime\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Innobrain\\SoakTime\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "class": "Innobrain\\SoakTime\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "innobrain/soak-time": true
        }
    }
}
